# Copy to .env and fill in values for your team. The .env file is gitignored.

# Comma-separated GitHub logins whose open PRs appear in the "Awaiting my review" tab.
# Required for the incoming-review view to show anything.
AUTHORS=teammate1,teammate2

# Comma-separated GitHub logins to ping on Slack when nobody has reviewed
# your PR yet. The "Nudge" button uses this set in "fresh" mode.
# The "#Channel" button always tags these users in the team channel.
FRESH_REVIEWERS=teammate1,teammate2

# Slack channel ID (e.g. C01ABCDEF) where the "#Channel" button posts.
# Find it in Slack: right-click the channel → View channel details → copy ID at bottom.
TEAM_CHANNEL_ID=

# Comma-separated GitHub Actions environment names you can deploy to from the My PRs tab.
# Each name renders as a "🚀 <env>" button on every PR row. Clicking it runs the workflow
# in the PR's repo whose filename starts with <env> (e.g. csi-2 → csi-2.yml or csi-2-deploy.yaml),
# dispatched against the PR's head branch.
DEPLOY_ENVS=

# Optional overrides (defaults shown).
# HOST=127.0.0.1
# PORT=8765
# CACHE_TTL=30
